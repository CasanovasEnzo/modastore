{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/productos/[id]/editar",
      "regex": "^/admin/productos/([^/]+?)/editar(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/productos/(?<nxtPid>[^/]+?)/editar(?:/)?$"
    },
    {
      "page": "/api/admin/orders/[id]",
      "regex": "^/api/admin/orders/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/orders/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/products/[id]",
      "regex": "^/api/admin/products/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/products/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/auth/[...all]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPall": "nxtPall"
      },
      "namedRegex": "^/api/auth/(?<nxtPall>.+?)(?:/)?$"
    },
    {
      "page": "/api/products/[slug]",
      "regex": "^/api/products/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/products/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/orden/[id]",
      "regex": "^/orden/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/orden/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/productos/[slug]",
      "regex": "^/productos/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/productos/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/ordenes",
      "regex": "^/admin/ordenes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/ordenes(?:/)?$"
    },
    {
      "page": "/admin/productos",
      "regex": "^/admin/productos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/productos(?:/)?$"
    },
    {
      "page": "/admin/productos/nuevo",
      "regex": "^/admin/productos/nuevo(?:/)?$",
